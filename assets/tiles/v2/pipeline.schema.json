{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "sprite-pipeline three-file model. Two roots under $defs: pipelineDoc (pipeline.json — spec + state: settings + items[] plus optional runState/presets; keyframes carry selected/selectedPath, NO candidates) and historyDoc (pipeline.history.json — itemId -> keyframeId -> candidate[]). Validated by the compact subset validator in scripts/manifest.mjs; select a root by name via validateDoc(doc, schema, 'pipelineDoc'|'historyDoc').",
  "$defs": {
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "safeArea": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "candidate": {
      "$comment": "A single keyframe candidate. `source` is its origin: `hand` (authored/edited in Aseprite, the home-grown path) or `pixellab` (AI review-pack / state). Candidates of BOTH sources share one pool per keyframe and compete at the G2 gate. `objectId`/`reviewObjectId` are PixelLab-only handles and absent on hand candidates.",
      "type": "object",
      "required": ["idx", "path", "status"],
      "properties": {
        "idx": { "type": "integer" },
        "path": { "type": "string" },
        "status": { "enum": ["requested", "generated", "failed", "rejected", "approved"] },
        "source": { "enum": ["hand", "pixellab"] },
        "llm": { "enum": ["pass", "fail"] },
        "reason": { "type": "string" },
        "objectId": { "type": "string" },
        "reviewObjectId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "keyframe": {
      "type": "object",
      "required": ["id", "prompt"],
      "properties": {
        "id": { "type": "string" },
        "prompt": { "type": "string" },
        "selected": { "type": ["integer", "null"] },
        "selectedPath": { "type": ["string", "null"] },
        "source": { "enum": ["hand", "pixellab", null] },
        "objectId": { "type": ["string", "null"] },
        "comment": { "type": "string" }
      },
      "additionalProperties": false
    },
    "animation": {
      "$comment": "Parent owns the full shape (type/required/properties/additionalProperties); the oneOf branches are ADDITIVE (each only adds a `required`) so they don't contradict the parent. The validator evaluates oneOf and the sibling keywords together. oneOf enforces: an idle (has `for`) XOR a transition (has `from`+`to`). status `rejected` = a human rejected the built animation in the viewer; the gap-fill planner re-animates it. `comment` is human feedback left in the viewer, cleared by the orchestrator once consumed.",
      "type": "object",
      "required": ["kind", "status"],
      "properties": {
        "kind": { "enum": ["idle", "transition"] },
        "for": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "frames": { "type": "integer" },
        "motion": { "type": "string" },
        "physics": { "type": "string" },
        "status": { "enum": ["pending", "generated", "rejected"] },
        "gif": { "type": "string" },
        "storyboard": { "type": "string" },
        "comment": { "type": "string" }
      },
      "additionalProperties": false,
      "oneOf": [
        { "required": ["for"] },
        { "required": ["from", "to"] }
      ]
    },
    "runState": {
      "$comment": "The orchestrator's progress broadcast to the viewer (e.g. 'Stage 2: generating grass candidates (2/4)'). Written via pipeline-patch run-state / await-review; the viewer only reads it.",
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["idle", "running", "waiting", "done"] },
        "detail": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "preset": {
      "$comment": "A named bundle of generation settings the intake interview offers as reusable defaults when adding new tiles. Keyed by preset name under pipelineDoc.presets.",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "canvas": { "$ref": "#/$defs/canvas" },
        "fps": { "type": "number" },
        "candidates": { "enum": [1, 2, 4] },
        "humanApproval": { "type": "boolean" },
        "idleFrames": { "type": "integer" },
        "transitionFrames": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "settings": {
      "$comment": "`reviewState` is the pause/resume handshake between the orchestrating agent and the browser viewer: pipeline-patch await-review sets 'reviewing', the viewer flips it to 'resume', and await-review deletes it on exit. Absent outside a review wait.",
      "type": "object",
      "required": ["styleSpec", "canvas", "fps", "candidates"],
      "properties": {
        "styleSpec": { "type": "string" },
        "canvas": { "$ref": "#/$defs/canvas" },
        "fps": { "type": "number" },
        "candidates": { "enum": [1, 2, 4] },
        "humanApproval": { "type": "boolean" },
        "autonomous": { "type": "boolean" },
        "reviewState": { "enum": ["reviewing", "resume"] }
      },
      "additionalProperties": false
    },
    "item": {
      "type": "object",
      "required": ["id", "master"],
      "properties": {
        "id": { "type": "string" },
        "basePrompt": { "type": "string" },
        "priors": { "type": "array", "items": { "type": "string" } },
        "canvas": { "$ref": "#/$defs/canvas" },
        "fps": { "type": "number" },
        "master": { "$ref": "#/$defs/keyframe" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/keyframe" } },
        "animations": { "type": "array", "items": { "$ref": "#/$defs/animation" } }
      },
      "additionalProperties": false
    },
    "pipelineDoc": {
      "type": "object",
      "required": ["settings", "items"],
      "properties": {
        "settings": { "$ref": "#/$defs/settings" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/item" } },
        "runState": { "$ref": "#/$defs/runState" },
        "presets": { "type": "object", "additionalProperties": { "$ref": "#/$defs/preset" } }
      },
      "additionalProperties": false
    },
    "historyDoc": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "items": { "$ref": "#/$defs/candidate" }
        }
      }
    }
  }
}
