        "hexes": ["#2a1c0c", "#543110", "#744617", "#9a6c34", "#c79a5a"]
      },
      {
        "name": "soil-earth",
        "hexes": ["#2c1c10", "#4e3413", "#6f4a1f", "#9a6c3a", "#c49a63"]
      },
      {
        "name": "wheat-gold",
        "hexes": ["#5a3a10", "#8a6418", "#c79a2e", "#e3c45a", "#f4e08a"]
      },
      {
        "name": "pumpkin-orange",
        "hexes": ["#4a1f10", "#8a3c12", "#c3671d", "#e8923c", "#f4b95e"]
