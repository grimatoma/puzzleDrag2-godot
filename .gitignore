# Godot 4 — generated / machine-local files.
# Keep project.godot, scenes, scripts, assets, and export_presets.cfg.

# Godot's import + cache directory (regenerated on open).
.godot/

# Imported resource binaries (regenerated from sources).
*.import.md5
.import/

# Export output.
/dist/
/build/
*.tmp

# Visual regression: failing-capture debug artifacts (per-run, not committed).
# The committed goldens live under tests/visual/__goldens__/<platform>/ and are kept.
tests/visual/__captures__/

# GdUnit4 run artifacts (per-run XML/HTML reports + adapter cache). The suites
# live under test/; the addon under addons/gdUnit4/ — both are committed. The
# generated reports/ and config caches are not.
reports/
.gdunit4_testadapter/
gdUnitRunner.cfg
GdUnitRunner.cfg

# Editor-local overrides.
override.cfg

# OS noise.
.DS_Store
Thumbs.db

# Node.js dependencies
node_modules/

# Claude CLI workspace caches
.claude/worktrees/
.claude/workspaces/
.claude/settings.local.json
.claude/.credentials.json
.env
.env.*
.mcp.json
