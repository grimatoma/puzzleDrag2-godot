; Engine configuration file for the Godot port of puzzleDrag2.
; Stored as plain text — diffable, hand-editable. See docs/godot-migration-plan.html.
;
; Generated/maintained by hand for the migration. Godot 4.6.

config_version=5

[application]

config/name="puzzleDrag2 (Godot)"
config/description="Godot 4 port of the React+Phaser drag-chain puzzle. Mobile-first."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"
; Engine boot splash — a 400x400 circular cottage medallion (authored by
; tools/gen_splash.py alongside the full splash art), drawn CENTERED at its
; natural size (stretch_mode=0, Disabled) on the vignette-indigo bg.
; The earlier full-bleed 720x1280 portrait scene letterboxed into a "portrait
; strip" on wide screens and then JUMPED to full width when SplashScreen.gd
; took over — a centred emblem reads as deliberate at any viewport aspect.
; use_filter=false keeps the x4-nearest pixels crisp (the web loader honours
; it as image-rendering:pixelated).
boot_splash/bg_color=Color(0.054902, 0.062745, 0.141176, 1)
boot_splash/image="res://assets/splash/splash_boot.png"
boot_splash/stretch_mode=0
boot_splash/use_filter=false

[display]

; Mobile-first portrait window. The 720×1280 base sets the 2D scale; stretch=expand
; lets the logical viewport GROW past the base in whichever dimension the device is
; larger (a wide/foldable screen gains width, a tall phone gains height) instead of
; pillar/letter-boxing the portrait content. The HUD is edge-anchored (top-bar +
; stockpile + bottom nav span the full width; the board stays centred), so it fills
; the extra space gracefully — see Main._layout / Board.layout_for, which re-run on
; every viewport size_changed. (Was "keep", which froze the content at 9:16 and left
; black bars on anything wider — the "doesn't get wider on my foldable" report.)
window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1
; M11 desktop-framing block. The base resolution stays 720×1280 (stretch scales it),
; but on desktop the window OPENS smaller than the tall base so it fits a 1080p screen,
; stays resizable, and is HiDPI-crisp. At non-9:16 window shapes stretch=keep pillarboxes
; the portrait content centred. The window-size override is a 0.75× 9:16 (540×960); the
; runtime minimum window size (360×640, a 9:16 floor) is applied in Main._ready() — Godot
; 4.6 has no project setting for it (it's a Window.min_size API call).
window/size/resizable=true
window/size/window_width_override=540
window/size/window_height_override=960
window/dpi/allow_hidpi=true

[gui]

; SmoothScroll addon (res://addons/SmoothScroll/) — per its README, disable pixel
; snapping so momentum/inertia scrolling interpolates content position smoothly
; instead of quantizing it to whole pixels each frame (which shows as micro-jitter
; during a flick). Godot's default is true; the addon ships this as false. Trade-off:
; Control/text positions are no longer pixel-snapped, which can shift the visual
; goldens — accepted for now, refresh goldens later.
common/snap_controls_to_pixels=false

[input_devices]

; Touch-first: treat touch as mouse so the same drag code serves both.
pointing/emulate_mouse_from_touch=true
pointing/emulate_touch_from_mouse=true

[rendering]

; GL Compatibility renderer — broadest mobile + HTML5 support.
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
